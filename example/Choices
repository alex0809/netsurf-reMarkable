homepage_url:about:welcome
fb_download_directory:/home/root/Downloads
fb_xochitl_restart_command:systemctl restart xochitl

scale:150

# Security / privacy hardening: JS off, no NPAPI plugins, no popups, no
# referer leak, ad blocker on. The user can flip any of these back from
# the Preferences page if desired.
enable_javascript:0
enable_plugins:0
block_popups:1
block_advertisements:1
send_referer:0

# Paper Pro has 2 GiB of RAM and a 4-core A53, so we can afford more
# parallel fetches and a bigger memory cache than the upstream defaults.
max_cached_fetch_handles:8
memory_cache_size:33554432

# Font paths for reMarkable Paper Pro (Ferrari): the device ships with
# the Noto family in /usr/share/fonts/ttf/noto/. For rM1/rM2 the upstream
# config pointed at DejaVu installed via Toltec under /opt/share/fonts.
# NotoMono has no bold flavour shipped, so monospace_bold reuses Regular.
fb_face_sans_serif:/usr/share/fonts/ttf/noto/NotoSans-Regular.ttf
fb_face_sans_serif_bold:/usr/share/fonts/ttf/noto/NotoSans-Bold.ttf
fb_face_sans_serif_italic:/usr/share/fonts/ttf/noto/NotoSans-Italic.ttf
fb_face_sans_serif_italic_bold:/usr/share/fonts/ttf/noto/NotoSans-BoldItalic.ttf
fb_face_serif:/usr/share/fonts/ttf/noto/NotoSerif-Regular.ttf
fb_face_serif_bold:/usr/share/fonts/ttf/noto/NotoSerif-Bold.ttf
fb_face_cursive:/usr/share/fonts/ttf/noto/NotoSerif-Italic.ttf
fb_face_monospace:/usr/share/fonts/ttf/noto/NotoMono-Regular.ttf
fb_face_monospace_bold:/usr/share/fonts/ttf/noto/NotoMono-Regular.ttf
fb_face_fantasy:/usr/share/fonts/ttf/noto/NotoSans-Italic.ttf

fb_toolbar_size:60
fb_furniture_size:40
fb_osk:1
